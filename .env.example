# ──────────────────────────────────────────────────────────────────────────────
# Shop Template — Umgebungsvariablen
# Kopiere diese Datei zu .env und fülle alle Werte aus.
# NIEMALS die .env-Datei in Git committen!
# ──────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
# URL deines Backends (lokal: http://localhost:3000)
VITE_API_URL=https://api.deinshop.de

# ── Supabase ──────────────────────────────────────────────────────────────────
# Zu finden unter: supabase.com → Projekt → Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Stripe ────────────────────────────────────────────────────────────────────
# Nur den PUBLIC Key hier — NIEMALS den Secret Key ins Frontend!
# Zu finden unter: dashboard.stripe.com → Developers → API Keys
VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ── SMTP / E-Mail ─────────────────────────────────────────────────────────────
# Für Bestellbestätigungen, Passwort-Reset etc.
# Empfohlen: Resend (resend.com) oder SendGrid
VITE_SMTP_FROM=bestellung@deinshop.de

# ── Shop-Konfiguration ────────────────────────────────────────────────────────
VITE_SHOP_NAME=Dein Shop Name
VITE_SHOP_URL=https://deinshop.de
VITE_SHOP_CURRENCY=EUR
VITE_SHOP_LOCALE=de-DE

# ── Feature Flags ─────────────────────────────────────────────────────────────
# true = aktiviert, false = deaktiviert
VITE_FEATURE_REVIEWS=true
VITE_FEATURE_WISHLIST=true
VITE_FEATURE_LIVE_CHAT=false
