# ══════════════════════════════════════════════════════════════════════════════
# ShopRay Backend — Umgebungsvariablen
# Kopiere diese Datei nach .env und trage deine Werte ein.
# Die .env-Datei wird NIEMALS in Git committet.
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Supabase ──────────────────────────────────────────────────────────────────
# Findest du unter: supabase.com → Dein Projekt → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Service-Role-Key: NUR im Backend! Hat vollen DB-Zugriff ohne RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret Key (beginnt mit sk_) — niemals im Frontend verwenden!
# Findest du unter: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
# Webhook Secret — wird beim Anlegen des Webhooks in Stripe angezeigt
# Stripe Dashboard → Developers → Webhooks → Endpoint hinzufügen
STRIPE_WEBHOOK_SECRET=whsec_...

# ── CORS ──────────────────────────────────────────────────────────────────────
# URLs deines Frontends und Admins (ohne / am Ende)
# Auf Vercel: https://dein-frontend.vercel.app
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
# FRONTEND_URL wird für interne Links in E-Mails verwendet
FRONTEND_URL=http://localhost:5173

# ── Admin-Auth (JWT) ──────────────────────────────────────────────────────────
# Bcrypt-Hash deines Admin-Passworts
# Generieren: node -e "const b=require('bcryptjs');b.hash('DEIN_PASSWORT',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$12$...
# Zufälliger 48-Byte-Hex-String: openssl rand -hex 48
JWT_SECRET=ersetze-mich-durch-langen-zufaelligen-string
# Verschlüsselt die 2FA-/TOTP-Secrets in der DB (AES-256-GCM). Stark empfohlen.
# Zufälliger Schlüssel: openssl rand -hex 32
# Wenn leer gelassen, werden TOTP-Secrets im Klartext gespeichert (rückwärtskompatibel).
# WICHTIG: Nach dem Setzen bestehende 2FA einmal neu einrichten ODER einmal einloggen
#          (Secrets werden beim nächsten erfolgreichen Login automatisch verschlüsselt).
TOTP_ENC_KEY=

# ── E-Mail (SMTP) ─────────────────────────────────────────────────────────────
# Empfohlen: Resend (resend.com) oder Postmark
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxx
SMTP_FROM_NAME=Dein Shop
SMTP_FROM_EMAIL=noreply@deinshop.de

# ── Shop-Angaben (Pflicht für Rechnungen nach § 14 UStG) ─────────────────────
SHOP_NAME=Mein Shop GmbH
SHOP_STREET=Musterstraße 1
SHOP_ZIP=12345
SHOP_CITY=Berlin
SHOP_COUNTRY=Deutschland
SHOP_EMAIL=info@meinshop.de
SHOP_PHONE=+49 30 123456        # optional
# Entweder Umsatzsteuer-ID ODER Steuernummer angeben (Pflicht!)
SHOP_VAT_ID=DE123456789         # Umsatzsteuer-ID
# SHOP_TAX_NUMBER=12/345/67890  # Alternative: Steuernummer (auskommentieren wenn VAT_ID gesetzt)

# ── Rechnungen ────────────────────────────────────────────────────────────────
# Präfix für Rechnungsnummern (Standard: RE → RE-2025-00001)
INVOICE_PREFIX=RE

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Schlüsselpaar generieren: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BAAAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_EMAIL=mailto:admin@meinshop.de

# ── DHL Business API (optional — nur wenn Versandlabels genutzt werden) ───────
# API-Key: developer.dhl.com → My Apps → App erstellen
DHL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Kundennummer (Abrechnungsnummer) — im DHL Geschäftskundenportal
DHL_BILLING_NUMBER=3333333333     # 3333333333 = Sandbox-Testnummer
DHL_SANDBOX=true                  # false für Produktion
# Absender-Daten für Versandlabels
DHL_SHIPPER_NAME=Mein Shop GmbH
DHL_SHIPPER_STREET=Musterstraße 1
DHL_SHIPPER_ZIP=12345
DHL_SHIPPER_CITY=Berlin

# ── Newsletter (Brevo, optional — siehe SETUP.md Abschnitt 12) ───────────────
# EU-gehostet, DSGVO-konform, Double-Opt-In eingebaut. Ohne BREVO_API_KEY ist
# das Newsletter-Feature inaktiv (Anmeldung wird lautlos verworfen, kein Fehler).
# BREVO_API_KEY=xkeysib-...
# BREVO_LIST_ID=3                       # Listen-ID aus Brevo (Contacts → Lists)
# BREVO_DOI_TEMPLATE_ID=1               # Double-Opt-In Template-ID (für DE empfohlen)
# BREVO_REDIRECT_URL=https://deinshop.de/newsletter-bestaetigt

# ── Demo-Modus (optional) ─────────────────────────────────────────────────────
# DEMO_MODE=true  # Blockiert schreibende Admin-Operationen für Demo-Instanzen
