{
  "name": "shopray-backend",
  "version": "1.0.0",
  "description": "ShopRay Backend — API, Stripe Webhooks, SMTP",
  "main": "dist/index.js",
  "scripts": {
    "dev":   "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js":  "^2.49.0",
    "cors":                   "^2.8.5",
    "dotenv":                 "^16.4.7",
    "express":                "^4.21.2",
    "express-rate-limit":     "^7.5.0",
    "helmet":                 "^8.0.0",
    "nodemailer":             "^6.10.1",
    "stripe":                 "^17.7.0",
    "zod":                    "^3.24.0"
  },
  "devDependencies": {
    "@types/cors":       "^2.8.17",
    "@types/express":    "^5.0.0",
    "@types/node":       "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "tsx":               "^4.19.2",
    "typescript":        "^5.8.3"
  }
}
