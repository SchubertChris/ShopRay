{
  "version": 2,
  "builds": [
    {
      "src":  "src/index.ts",
      "use":  "@vercel/node"
    }
  ],
  "routes": [
    {
      "src":  "/(.*)",
      "dest": "src/index.ts"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" }
      ]
    }
  ]
}
