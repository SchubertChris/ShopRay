# ══════════════════════════════════════════════════════════════════════════════
# ShopRay Admin — Umgebungsvariablen
# Kopiere diese Datei nach .env und trage deine Werte ein.
# Die .env-Datei wird NIEMALS in Git committet.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dieselben Werte wie im Frontend — gleiche Datenbank, gleiche Instanz
# Findest du unter: supabase.com → Dein Projekt → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Backend API ───────────────────────────────────────────────────────────────
# URL deines Backends (lokal: http://localhost:5000/api)
# Auf Vercel: https://DEINE-BACKEND-URL.vercel.app/api
VITE_API_URL=http://localhost:5000/api
