# ══════════════════════════════════════════════════════════════════════════════
# ShopRay Admin — Umgebungsvariablen
# Kopiere diese Datei nach .env und trage deine Werte ein.
# Die .env-Datei wird NIEMALS in Git committet.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dieselben Werte wie im Frontend — gleiche Datenbank, gleiche Instanz
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service-Role-Key: NUR für den Admin! Niemals im Frontend verwenden!
# Hat vollen Datenbankzugriff ohne RLS-Einschränkungen.
# Findest du unter: supabase.com → Dein Projekt → Settings → API → service_role
VITE_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Publishable Key für das Admin-Dashboard (Zahlungsübersicht)
VITE_STRIPE_PUBLIC_KEY=pk_live_...

# ── App-Einstellungen ─────────────────────────────────────────────────────────
VITE_APP_NAME=ShopRay Admin
VITE_SHOP_URL=https://deinshop.de
VITE_ADMIN_URL=https://admin.deinshop.de
