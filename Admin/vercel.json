{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://shopray-backend.vercel.app/api/:path*" },
    { "source": "/(.*)",       "destination": "/index.html" }
  ]
}
