# ══════════════════════════════════════════════════════════════════════════════
# ShopRay Frontend — Umgebungsvariablen
# Kopiere diese Datei nach .env und trage deine Werte ein.
# Die .env-Datei wird NIEMALS in Git committet.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
# Findest du unter: supabase.com → Dein Projekt → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Publishable Key (beginnt mit pk_) — niemals den Secret Key hier eintragen!
# Findest du unter: dashboard.stripe.com → Developers → API Keys
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# ── App-Einstellungen ─────────────────────────────────────────────────────────
VITE_APP_NAME=Dein Shop Name
VITE_APP_URL=https://deinshop.de

# ── Backend API ───────────────────────────────────────────────────────────────
# URL deines Backends (lokal: http://localhost:5000/api/v1)
VITE_API_BASE_URL=http://localhost:5000/api/v1
